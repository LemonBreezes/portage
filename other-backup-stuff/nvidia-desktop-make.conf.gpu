# Per-host GPU settings, sourced from /etc/portage/make.conf.
# Not tracked in git; reference copy lives in other-backup-stuff/.
#
# UGPU is concatenated into USE in make.conf — put per-vendor USE flags
# here (nvidia, amdgpu, intel-media, vaapi, vdpau, vulkan, opencl, cuda…).
# VIDEO_CARDS lists the X/Wayland drivers to build.

VIDEO_CARDS="nvidia"
UGPU="nvidia vdpau nvenc vulkan opengl cuda"

# CUDA toolchain (nvidia-only; remove on systems without CUDA).
# CUDA 12.9 supports gcc up to 14; gcc-16 is too new for nvcc.
CUDAHOSTCXX="/usr/x86_64-pc-linux-gnu/gcc-bin/14"
NVCC_PREPEND_FLAGS="--compiler-bindir /usr/x86_64-pc-linux-gnu/gcc-bin/14"
CUDA_ARCH="sm_120"
CUDA_ARCH_BIN="12.0"
CUDA_GENERATION="Blackwell"
CUDA_VERBOSE="false"
TORCH_CUDA_ARCH_LIST="12.0"
