# =====================================================================
# LAPTOP variant (ASUS ROG Strix G713PI — "helium").
# Symlink only this file as /etc/kernel/config.d/00-local-laptop.config
# on the laptop. The desktop uses 00-local-desktop.config instead; the
# meaningful difference is the lockdown level (laptop=CONFIDENTIALITY,
# the maximum; desktop=INTEGRITY, kept lower to retain perf-stat tooling).
# =====================================================================
#
# Local kernel config fragments. Anything in /etc/kernel/config.d/*.config
# is merged LAST by sys-kernel/gentoo-kernel, so settings here override the
# distribution config and the auto-generated modules-sign config.
#
# Already handled automatically by USE=modules-sign + MODULES_SIGN_* in
# make.conf — do NOT set these here:
#   CONFIG_MODULE_SIG, CONFIG_MODULE_SIG_FORCE, CONFIG_MODULE_SIG_ALL,
#   CONFIG_MODULE_SIG_SHA512, CONFIG_MODULE_SIG_KEY

# === Kernel lockdown ===
# gentoo-kernel[hardened] ships with CONFIG_LSM="landlock,yama,bpf" and
# CONFIG_SECURITY_LOCKDOWN_LSM=n, so lockdown does nothing by default.
# Keep the LSM loaded and orderable, and force CONFIDENTIALITY at boot.
# LSM_EARLY=y means the level is in effect from early boot, before initramfs.
CONFIG_SECURITY_LOCKDOWN_LSM=y
CONFIG_SECURITY_LOCKDOWN_LSM_EARLY=y
CONFIG_LSM="landlock,lockdown,yama,bpf"

# Lockdown level is FORCE_CONFIDENTIALITY — the maximum. Hibernation is no
# longer in scope for this laptop (see "=== Hibernation ===" below), so the
# strongest mode is on the table. CONFIDENTIALITY enforces everything
# INTEGRITY does (no unsigned module load, no /dev/mem, no kprobes, no BPF
# kernel-memory writes, no kexec_load, no hibernation) PLUS the
# confidentiality tier of the lockdown enum: no /proc/kcore, no
# /proc/kallsyms addresses, no perf kernel sampling, and no BPF reads of
# kernel memory. That last one closes the path by which a root attacker
# could dump the live ZFS encryption key out of kernel RAM — the primary
# threat this box cares about.
#
# Costs accepted (eyes open):
#   * perf-stat / perf-record kernel-side profiling stops working
#     (LOCKDOWN_PERF, LOCKDOWN_KCORE, LOCKDOWN_KPROBES). The desktop stays
#     at INTEGRITY precisely to keep this; the laptop gives it up.
#   * sched_ext (scx) schedulers from 30-latency-scx.config may fail to
#     attach under LOCKDOWN_BPF_READ_KERNEL if their struct_ops programs
#     read kernel memory via probe helpers. If scx_loader reports the
#     scheduler refusing to load, the in-kernel EEVDF scheduler still runs
#     unchanged — drop the level to INTEGRITY here if scx is needed back.
#
# Secure Boot is off in firmware, so there's no implicit lockdown call
# from EFI; if SB is re-enabled later it would force INTEGRITY, which is
# weaker than what we set here, so this stays the effective floor.
# CONFIG_LOCK_DOWN_KERNEL_FORCE_NONE is not set
# CONFIG_LOCK_DOWN_KERNEL_FORCE_INTEGRITY is not set
CONFIG_LOCK_DOWN_KERNEL_FORCE_CONFIDENTIALITY=y

# === Hibernation ===
# Removed. CONFIDENTIALITY lockdown blocks hibernation at runtime anyway
# (LOCKDOWN_HIBERNATION sits below INTEGRITY_MAX in the enum, so the
# `kernel_locked_down >= LOCKDOWN_HIBERNATION` check fires), but we also
# compile the swsusp/resume code out entirely — smaller attack surface and
# no half-wired resume path. /sys/power/disk disappears; suspend-to-RAM
# (CONFIG_SUSPEND) is unaffected. The matching dracut `resume` module and
# any resume= cmdline arg have been dropped; LUKS swap is still unlocked in
# the initramfs and used as plain encrypted swap.
# CONFIG_HIBERNATION is not set

# === Other hardening (already validated to apply) ===
# Disable kexec_load() (legacy unsigned). Signed kexec via kexec_file_load()
# still works under lockdown.
CONFIG_KEXEC=n
# Bundle of upstream-recommended self-protection options curated by Gentoo.
CONFIG_GENTOO_KERNEL_SELF_PROTECTION=y

# === Enforced signature checking on kexec_file_load ===
# Without these, lockdown still lets root kexec_file_load() any unsigned
# kernel — defeating lockdown's whole point (an attacker who gains root
# could kexec into a kernel with lockdown disabled and dump the live ZFS
# encryption key from memory). With them, the target kernel must carry a
# PE/Authenticode signature signed by a key in .builtin_trusted_keys.
# /etc/kernel/postinst.d/95-zbm-install adds a second signature to
# /boot/vmlinuz-<ver> with $MODULES_SIGN_CERT — the same cert embedded
# at kernel-build time — so kexec validates without further setup.
CONFIG_KEXEC_SIG=y
CONFIG_KEXEC_SIG_FORCE=y
CONFIG_KEXEC_BZIMAGE_VERIFY_SIG=y
