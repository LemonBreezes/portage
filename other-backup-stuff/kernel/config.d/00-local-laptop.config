# =====================================================================
# LAPTOP variant (ASUS ROG Strix G713PI — "helium").
# Symlink only this file as /etc/kernel/config.d/00-local-laptop.config
# on the laptop. The desktop uses 00-local-desktop.config instead; the
# only meaningful difference is the lockdown level (laptop=NONE to
# enable hibernation, desktop=INTEGRITY).
# =====================================================================
#
# Local kernel config fragments. Anything in /etc/kernel/config.d/*.config
# is merged LAST by sys-kernel/gentoo-kernel, so settings here override the
# distribution config and the auto-generated modules-sign config.
#
# Already handled automatically by USE=modules-sign + MODULES_SIGN_* in
# make.conf — do NOT set these here:
#   CONFIG_MODULE_SIG, CONFIG_MODULE_SIG_FORCE, CONFIG_MODULE_SIG_ALL,
#   CONFIG_MODULE_SIG_SHA512, CONFIG_MODULE_SIG_KEY

# === Kernel lockdown ===
# gentoo-kernel[hardened] ships with CONFIG_LSM="landlock,yama,bpf" and
# CONFIG_SECURITY_LOCKDOWN_LSM=n, so lockdown does nothing by default.
# Keep the LSM loaded and orderable so it CAN be enabled dynamically or
# triggered by Secure Boot, but don't force a default level at boot.
CONFIG_SECURITY_LOCKDOWN_LSM=y
CONFIG_SECURITY_LOCKDOWN_LSM_EARLY=y
CONFIG_LSM="landlock,lockdown,yama,bpf"

# Lockdown level is FORCE_NONE because hibernation is in scope for this
# laptop. LOCKDOWN_HIBERNATION (enum value 5) sits below both
# LOCKDOWN_INTEGRITY_MAX and LOCKDOWN_CONFIDENTIALITY_MAX in the kernel
# enum, so the check `kernel_locked_down >= LOCKDOWN_HIBERNATION` fires
# in EITHER mode — i.e. lockdown=integrity blocks hibernation too, not
# just confidentiality. The earlier choice of INTEGRITY was based on the
# incorrect assumption that it permitted hibernation; it did not, which
# is why /sys/power/disk showed [disabled] and resume=… hung the boot.
#
# Trade-off accepted: a root attacker on the running system can now
# read /proc/kcore, run kprobes, and BPF-read kernel memory — meaning
# they could extract the live ZFS encryption key. Mitigated by SELinux
# and the absence of remote services, but real. The hibernation image
# itself isn't a leak vector: it lands on LUKS2-encrypted swap whose
# keyfile lives on the ZFS-encrypted root, so it inherits the same
# passphrase gate as everything else.
#
# Secure Boot is off in firmware, so there's no implicit lockdown call
# from EFI to worry about; if SB is re-enabled later, it will force
# integrity automatically and break hibernation again.
CONFIG_LOCK_DOWN_KERNEL_FORCE_NONE=y
# CONFIG_LOCK_DOWN_KERNEL_FORCE_INTEGRITY is not set
# CONFIG_LOCK_DOWN_KERNEL_FORCE_CONFIDENTIALITY is not set

# === Other hardening (already validated to apply) ===
# Disable kexec_load() (legacy unsigned). Signed kexec via kexec_file_load()
# still works under lockdown.
CONFIG_KEXEC=n
# Bundle of upstream-recommended self-protection options curated by Gentoo.
CONFIG_GENTOO_KERNEL_SELF_PROTECTION=y

# === Enforced signature checking on kexec_file_load ===
# Without these, lockdown still lets root kexec_file_load() any unsigned
# kernel — defeating lockdown's whole point (an attacker who gains root
# could kexec into a kernel with lockdown disabled and dump the live ZFS
# encryption key from memory). With them, the target kernel must carry a
# PE/Authenticode signature signed by a key in .builtin_trusted_keys.
# /etc/kernel/postinst.d/95-zbm-install adds a second signature to
# /boot/vmlinuz-<ver> with $MODULES_SIGN_CERT — the same cert embedded
# at kernel-build time — so kexec validates without further setup.
CONFIG_KEXEC_SIG=y
CONFIG_KEXEC_SIG_FORCE=y
CONFIG_KEXEC_BZIMAGE_VERIFY_SIG=y
