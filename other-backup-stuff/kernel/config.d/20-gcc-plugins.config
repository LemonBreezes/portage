# =====================================================================
# GCC plugins — RE-ENABLED after verifying they build under gcc-16.
# (Replaces the old 20-no-gcc-plugins.config.) Shared laptop + desktop.
# =====================================================================
#
# History: this fragment previously DISABLED CONFIG_GCC_PLUGINS on the
# theory that gcc-16 (dropped CONST_CAST_TREE, changed internal C++ ABI)
# could not compile scripts/gcc-plugins/*.c. Re-tested 2026-06-01 with
# gcc 16.1.0 p1 against the 6.18 plugin source: latent_entropy and
# stackleak both compile cleanly using the kernel's host C++ standard
# (gcc-16 defaults to gnu++17 — the ONLY failure was forcing the obsolete
# -std=gnu++11, which the kernel build does not do). The blanket disable
# was stale, so plugins are back on.
#
# The kernel build is the final validator: if 7.0's plugin source ever
# regresses against gcc-16, the emerge fails early at the HOSTCXX plugin
# step — revert this fragment and rebuild.

CONFIG_GCC_PLUGINS=y

# STACKLEAK: erase the kernel stack on return to userspace — kills stack
# infoleaks and uninitialized-stack exploit primitives. Small perf cost on
# syscall-heavy paths; acceptable on this already-hardened box.
CONFIG_GCC_PLUGIN_STACKLEAK=y
# CONFIG_STACKLEAK_METRICS is not set
# CONFIG_STACKLEAK_RUNTIME_DISABLE is not set

# LATENT_ENTROPY: extra boot-time entropy (this is what the hardened
# distconfig enabled before plugins were turned off). Negligible cost.
CONFIG_GCC_PLUGIN_LATENT_ENTROPY=y

# RANDSTRUCT: deliberately LEFT OFF for now. RANDSTRUCT_FULL randomizes
# sensitive struct layouts with a per-build seed, forcing EVERY out-of-tree
# module — i.e. ZFS, our root fs — to be rebuilt against that exact seed on
# every kernel build, or the module won't load and root won't mount. Too
# risky to introduce in the SAME rebuild that jumps to kernel 7.0 AND
# zfs-2.4.0_rc2. Add it later in isolation once 7.0+ZFS is proven: flip to
# CONFIG_RANDSTRUCT_FULL and rebuild ZFS (@module-rebuild) in lockstep.
# Pinned to NONE explicitly so the hardened distconfig cannot silently
# select FULL now that GCC_PLUGINS is back on.
CONFIG_RANDSTRUCT_NONE=y
# CONFIG_RANDSTRUCT_FULL is not set
# CONFIG_RANDSTRUCT_PERFORMANCE is not set
