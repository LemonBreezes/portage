# =====================================================================
# Latency tuning + sched_ext (scx) — shared by laptop and desktop.
# Symlink as /etc/kernel/config.d/30-latency-scx.config.
# Merged LAST (after 00/10/20), so these win over the hardened
# distconfig. Goal: lower scheduling latency WITHOUT changing kernel,
# keeping the full gentoo-kernel[hardened] + SELinux + module-sign
# stack intact. Throughput is deprioritized but we stay non-RT.
# Added 2026-05-29.
# =====================================================================

# === Timer tick: 300 -> 1000 Hz ===
# Hardened distconfig ships CONFIG_HZ_300. 1000 Hz shortens the
# scheduler tick to 1 ms, cutting worst-case wakeup latency for
# interactive/audio/gaming tasks. Cost: marginally more timer overhead
# and a touch more power draw under light load — acceptable on this
# box. (NO_HZ_FULL is not enabled; dynticks still idles the tick.)
# CONFIG_HZ_100 is not set
# CONFIG_HZ_250 is not set
# CONFIG_HZ_300 is not set
CONFIG_HZ_1000=y
CONFIG_HZ=1000

# === Preemption: LAZY -> full PREEMPT (as the compiled default) ===
# Hardened distconfig selects PREEMPT_LAZY. Full CONFIG_PREEMPT gives
# the lowest non-RT latency (kernel is preemptible except in critical
# sections). Because CONFIG_PREEMPT_DYNAMIC=y is retained, the model is
# still switchable at boot WITHOUT recompiling — append one of:
#     preempt=full        (this default — lowest latency)
#     preempt=lazy        (the old behavior — best latency/throughput balance)
#     preempt=voluntary   (throughput-leaning)
# to the kernel command line to A/B test. We bake 'full' as the default
# because latency is the stated priority here.
# CONFIG_PREEMPT_NONE is not set
# CONFIG_PREEMPT_VOLUNTARY is not set
# CONFIG_PREEMPT_LAZY is not set
CONFIG_PREEMPT=y

# === sched_ext: pluggable BPF CPU schedulers (sys-kernel/scx) ===
# Enables loading userspace-defined schedulers (scx_lavd for latency,
# scx_rusty, scx_bpfland, ...) at RUNTIME. With nothing loaded the
# in-kernel EEVDF scheduler runs exactly as before, so this is a safe,
# opt-in capability — flip to scx_lavd via scx-loader when you want
# BORE/CachyOS-class interactivity, drop back to EEVDF instantly.
CONFIG_SCHED_CLASS_EXT=y

# === BTF — REQUIRED by scx, not optional ===
# scx schedulers are BPF struct_ops programs; they can only attach when
# the kernel exposes vmlinux BTF (/sys/kernel/btf/vmlinux). The hardened
# distconfig sets CONFIG_DEBUG_INFO_NONE, which omits BTF entirely, so we
# must turn DWARF+BTF on. pahole (dev-util/pahole, v131 here) generates
# the BTF at build time.
#
# Costs / implications, eyes open:
#   * Longer kernel build and higher build-time RAM (DWARF generation).
#   * vmlinux grows; the installed bzImage grows only modestly (BTF is
#     compact; bulky DWARF stays in the uninstalled vmlinux).
#   * Minor info exposure: /sys/kernel/btf/vmlinux publishes kernel type
#     layout. Considered acceptable; it's standard for any BPF/CO-RE host
#     and is not gated by lockdown.
# CONFIG_DEBUG_INFO_NONE is not set
CONFIG_DEBUG_INFO_DWARF_TOOLCHAIN_DEFAULT=y
CONFIG_DEBUG_INFO_BTF=y
