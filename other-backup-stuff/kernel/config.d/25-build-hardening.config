# =====================================================================
# Build-time self-protection (compiler features — NOT gcc plugins).
# Merged after 20-gcc-plugins. Shared laptop + desktop. Added 2026-06-01.
# =====================================================================

# ZERO_CALL_USED_REGS: zero call-clobbered registers on function return so
# less stale data is left behind for ROP gadgets / register infoleaks.
# Pure compiler flag (-fzero-call-used-regs); gcc 16.1.0 supports it
# (CONFIG_CC_HAS_ZERO_CALL_USED_REGS=y, verified). Low-moderate perf cost.
CONFIG_ZERO_CALL_USED_REGS=y

# Do not auto-load TTY line disciplines on demand (TIOCSETD attack surface).
# Compile-time twin of dev.tty.ldisc_autoload=0 in 99-hardening.conf, baked
# into the kernel so it holds even before sysctls are applied. Default =y.
# CONFIG_LDISC_AUTOLOAD is not set

# NOTE: UBSAN_TRAP deliberately NOT enabled here. UBSAN_BOUNDS_STRICT is
# already on (=y) and currently LOGS out-of-bounds. UBSAN_TRAP would
# escalate any detected OOB — including a false positive — into a kernel
# trap/panic. Too aggressive to flip in the same step as a brand-new
# ~amd64 7.0 kernel; revisit once 7.0 has run clean for a while.
