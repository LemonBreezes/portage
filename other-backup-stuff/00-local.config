# Local kernel config fragments. Anything in /etc/kernel/config.d/*.config
# is merged LAST by sys-kernel/gentoo-kernel, so settings here override the
# distribution config and the auto-generated modules-sign config.
#
# Already handled automatically by USE=modules-sign + MODULES_SIGN_* in
# make.conf — do NOT set these here:
#   CONFIG_MODULE_SIG, CONFIG_MODULE_SIG_FORCE, CONFIG_MODULE_SIG_ALL,
#   CONFIG_MODULE_SIG_SHA512, CONFIG_MODULE_SIG_KEY
#
# Suggested options for the hostile-state Secure Boot model. Uncomment
# (remove the leading #) the lines you want, then re-emerge gentoo-kernel.
#
# Force kernel lockdown even without Secure Boot. With SB enabled, the
# kernel auto-engages lockdown=integrity anyway; setting it here makes it
# unconditional. CONFIDENTIALITY is stricter (also blocks /dev/mem,
# /dev/kmem, kprobes, hibernate, eBPF kallsyms, etc.) — pick one:
#
CONFIG_LOCK_DOWN_KERNEL_FORCE_INTEGRITY=y
CONFIG_LOCK_DOWN_KERNEL_FORCE_CONFIDENTIALITY=y
#
# Disable kexec_load() (the legacy unsigned interface). Signed kexec via
# kexec_file_load() still works under lockdown.
#
CONFIG_KEXEC=n
#
# Stricter init_on_alloc/free can be enforced at config time too, but the
# cmdline already sets them at runtime so this is redundant.
CONFIG_GENTOO_KERNEL_SELF_PROTECTION=y
