Annotate find_gitignores' return type with PathSpec[Any].

pathspec >= 1.0 made PathSpec a Generic[TPattern]. mypy self-checks
during build with strict generics enabled, which fails with
"Missing type arguments for generic type 'PathSpec' [type-arg]".

--- a/mypy/modulefinder.py
+++ b/mypy/modulefinder.py
@@ -14,7 +14,7 @@
 import subprocess
 import sys
 from enum import Enum, unique
-from typing import Final, TypeAlias as _TypeAlias
+from typing import Any, Final, TypeAlias as _TypeAlias

 from pathspec import PathSpec
 from pathspec.patterns.gitignore import GitIgnorePatternError
@@ -724,7 +724,7 @@


 @functools.lru_cache
-def find_gitignores(dir: str) -> list[tuple[str, PathSpec]]:
+def find_gitignores(dir: str) -> list[tuple[str, PathSpec[Any]]]:
     parent_dir = os.path.dirname(dir)
     if parent_dir == dir or os.path.exists(os.path.join(dir, ".git")):
         parent_gitignores = []
